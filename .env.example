# ============================================================
# Cairn — environment template
# ============================================================
# Copy this file to `.env.local` and fill in what you need.
# The app runs in TWO modes selected by DATA_BACKEND:
#
#   DATA_BACKEND=local     -> JSON file store, zero external services (default)
#   DATA_BACKEND=supabase  -> Supabase Postgres + Auth (for Vercel deploy)
#
# You only need the block that matches your chosen mode.
# ============================================================

# ---- Mode selector ----
DATA_BACKEND=local

# ---- AI provider (optional but recommended) ----
# Cairn is provider-agnostic. Configure ONE of the following:
#   GEMINI_API_KEY    -> Google Gemini (recommended; works out of the box)
#   ANTHROPIC_API_KEY -> Anthropic Claude
# Leave both blank to run fully offline with built-in generation.
GEMINI_API_KEY=
# Optional: point at any OpenAI-compatible Gemini gateway (e.g. a proxy).
GEMINI_BASE_URL=
# Optional: override the model id (defaults to a sensible per-provider value).
GEMINI_MODEL=
# Optional Anthropic settings:
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
CAIRN_MODEL=

# ---- Local backend only ----
# Secret used to sign local session cookies. CHANGE THIS in production.
CAIRN_SECRET=change-me-to-a-long-random-string
# Optional: where the JSON store lives (defaults to ./data)
# CAIRN_DATA_DIR=./data

# ============================================================
# Supabase backend (only needed when DATA_BACKEND=supabase)
# ============================================================
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
# SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
