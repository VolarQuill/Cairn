# ============================================================
# Cairn — environment template
# ============================================================
# Copy this file to `.env.local` and fill in what you need.
# The app runs in TWO modes selected by DATA_BACKEND:
#
#   DATA_BACKEND=local     -> JSON file store, zero external services (default)
#   DATA_BACKEND=supabase  -> Supabase Postgres + Auth (for Vercel deploy)
#
# You only need the block that matches your chosen mode.
# ============================================================

# ---- Mode selector ----
DATA_BACKEND=local

# ---- AI provider (defaults below work out-of-the-box on Vercel) ----
# Cairn ships configured for OpenRouter's free model. Only GEMINI_API_KEY
# is secret; the base URL + model id are public/non-sensitive.
# To use any other provider, swap these for your own values (BYOK).
GEMINI_API_KEY=sk-or-v1-your-openrouter-key
GEMINI_BASE_URL=https://openrouter.ai/api/v1
GEMINI_MODEL=tencent/hy3:free
# Optional Anthropic settings (leave blank unless you prefer Claude):
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
CAIRN_MODEL=

# ---- Local backend only ----
# Secret used to sign local session cookies. CHANGE THIS in production.
CAIRN_SECRET=change-me-to-a-long-random-string
# Optional: where the JSON store lives (defaults to ./data)
# CAIRN_DATA_DIR=./data

# ============================================================
# Supabase backend (REQUIRED when DATA_BACKEND=supabase)
# From Supabase → Project Settings → API
# ============================================================
DATA_BACKEND=supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
# Service-role key is REQUIRED: the server-side DB layer uses it to bypass
# Row Level Security. The anon key alone is blocked by RLS on writes.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
